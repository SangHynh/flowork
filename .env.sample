# --- FLOWORK BOT CONFIGURATION (MANDATORY) ---

# 1. API Token của Bot (Lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Lưu ý: Các cấu hình khác như thư mục dự án và session đã được mặc định hóa.
# Bạn có thể tự thêm PROJECTS_DIR=... nếu muốn đổi thư mục dự án gốc. (mặc định ổ e)
PROJECTS_DIR=e:\