# --- FLOWORK BOT CONFIGURATION ---

# 1. Telegram Bot Token (Lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# 2. ID người dùng được phép sử dụng (Bảo mật: lấy từ @userinfobot)
ALLOWED_USER_ID=YOUR_TELEGRAM_ID_HERE

# 3. Thư mục gốc chứa các dự án của bạn (VD: e:/fullstack hoặc /home/user/projects)
PROJECTS_DIR=e:/fullstack

# 4. Cấu hình đường dẫn lưu phiên làm việc (Mặc định: state/session.json)
SESSION_PATH=state/session.json

# 5. Cài đặt các thông số khác (Optional)
# LOG_LEVEL=debug
